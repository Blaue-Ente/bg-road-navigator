{
  "version": 2,
  "builds": [
    {
      "src": "next.config.ts",
      "dest": "next.config.js",
      "config": {
        "dependencyMode": "external"
      }
    },
    {
      "src": "next.config.js",
      "use": "@vercel/next-plugin"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "/api/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "cleanWebpackCache": true
}